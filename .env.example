# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# MCP Server Configuration
AWS_MCP_WORKING_DIR=/tmp/aws-mcp-work
AWS_MCP_TRANSPORT=stdio
AWS_MCP_REQUIRE_CONFIRMATION=true
AWS_MCP_LOG_LEVEL=INFO

# HTTP Transport Settings (only used if AWS_MCP_TRANSPORT=http)
AWS_MCP_HOST=127.0.0.1
AWS_MCP_PORT=8080
